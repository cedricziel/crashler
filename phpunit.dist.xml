<?xml version="1.0" encoding="UTF-8"?>

<!-- https://phpunit.readthedocs.io/en/latest/configuration.html -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         colors="true"
         failOnDeprecation="true"
         failOnNotice="true"
         failOnWarning="true"
         bootstrap="tests/bootstrap.php"
         cacheDirectory=".phpunit.cache"
         executionOrder="random"
>
    <php>
        <ini name="display_errors" value="1" />
        <ini name="error_reporting" value="-1" />
        <!-- Functional tests across three signals each allocate ~18 MiB
             strings to exercise the decompressed-body cap; cumulative
             pressure exceeds the 128 MiB default. -->
        <ini name="memory_limit" value="512M" />
        <server name="APP_ENV" value="test" force="true" />
        <server name="SHELL_VERBOSITY" value="-1" />
        <server name="BROWSER_ALWAYS_START_WEBSERVER" value="1"/>
        <!-- Required by InvitationMailer when invitation tests dispatch
             a real (in-memory) email; an unset from-address makes the
             mailer throw with a clear bootstrap error. Setting it here
             is harmless for other tests because the mailer is only
             reached when InvitationController::create() runs. -->
        <server name="CRASHLER_INVITATIONS_FROM_ADDRESS" value="noreply@crashler.test"/>
    </php>

    <testsuites>
        <testsuite name="unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="component">
            <directory>tests/Component</directory>
        </testsuite>
        <testsuite name="functional">
            <directory>tests/Functional</directory>
        </testsuite>
    </testsuites>

    <source ignoreSuppressionOfDeprecations="true"
            ignoreIndirectDeprecations="true"
            restrictNotices="true"
            restrictWarnings="true"
    >
        <include>
            <directory>src</directory>
        </include>
        <exclude>
            <directory>src/Story</directory>
            <file>src/Kernel.php</file>
            <!-- Composer\Hooks is a ~30-line post-install hint that runs
                 in composer's runtime; its dependencies (Composer\IO,
                 Composer\Script\Event) aren't autoloadable from PHPUnit
                 scope. Excluded from coverage tracking. -->
            <directory>src/Composer</directory>
        </exclude>

        <deprecationTrigger>
            <method>Doctrine\Deprecations\Deprecation::trigger</method>
            <method>Doctrine\Deprecations\Deprecation::delegateTriggerToBackend</method>
            <function>trigger_deprecation</function>
        </deprecationTrigger>
    </source>

    <coverage includeUncoveredFiles="true"
              ignoreDeprecatedCodeUnits="true"
              disableCodeCoverageIgnore="false"
    >
        <report>
            <text outputFile="php://stdout" showOnlySummary="true" />
            <html outputDirectory="var/coverage/html" />
            <clover outputFile="var/coverage/clover.xml" />
        </report>
    </coverage>

    <extensions>
        <bootstrap class="Zenstruck\Foundry\PHPUnit\FoundryExtension" />
    </extensions>
</phpunit>
