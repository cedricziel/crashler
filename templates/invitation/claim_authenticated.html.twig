{% extends 'base.html.twig' %}

{% block title %}Accept invitation{% endblock %}

{% block body %}
<main style="max-width: 28rem; margin: 4rem auto; font-family: -apple-system, system-ui, sans-serif; text-align: center;">
    <h1>You're invited</h1>
    <p>to join <strong>{{ invitation.tenant.name }}</strong> (<code>/{{ invitation.tenant.slug }}</code>) as <code>{{ invitation.role.value }}</code>.</p>
    <p style="color: #666; font-size: 0.9em;">Signed in as {{ app.user.email }}.</p>

    <form method="post" action="{{ path('app_invitation_accept', {token: invitation.token}) }}" style="margin-top: 2rem;">
        <input type="hidden" name="_token" value="{{ csrf_token('accept-invitation-' ~ invitation.id) }}">
        <button type="submit" style="padding: 0.6rem 1.25rem; background: #222; color: #fff; border: none; cursor: pointer; font-size: 1rem;">Accept invitation</button>
    </form>

    <p style="margin-top: 2rem; font-size: 0.85em; color: #666;">
        <a href="{{ path('app_logout') }}">Sign out</a>
    </p>
</main>
{% endblock %}
