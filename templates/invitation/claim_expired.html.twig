{% extends 'base.html.twig' %}

{% block title %}Invitation expired{% endblock %}

{% block body %}
<main style="max-width: 28rem; margin: 4rem auto; font-family: -apple-system, system-ui, sans-serif; text-align: center;">
    <h1>This invitation has expired</h1>
    <p style="color: #666;">Or it was never valid. Either way, the link no longer works.</p>
    <p style="font-size: 0.9em; color: #666;">Ask whoever sent you the invitation to issue a new one.</p>
</main>
{% endblock %}
