{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/hal": "^4.3",
        "api-platform/json-api": "^4.3",
        "api-platform/symfony": "^4.3.4",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.3",
        "easycorp/easyadmin-bundle": "^5.0",
        "flow-php/parquet": "^0.37.0",
        "open-telemetry/gen-otlp-protobuf": "^1.9",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "symfony/apache-pack": "^1.0.1",
        "symfony/asset": "8.0.*",
        "symfony/asset-mapper": "8.0.*",
        "symfony/clock": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/expression-language": "8.0.*",
        "symfony/flex": "^2.10",
        "symfony/form": "8.0.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-client": "8.0.*",
        "symfony/intl": "8.0.*",
        "symfony/mailer": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^3.0|^4.0.2",
        "symfony/notifier": "8.0.*",
        "symfony/process": "8.0.*",
        "symfony/property-access": "8.0.*",
        "symfony/property-info": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/serializer": "8.0.*",
        "symfony/stimulus-bundle": "^3.0",
        "symfony/string": "8.0.*",
        "symfony/translation": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/uid": "8.0.*",
        "symfony/ux-live-component": "^3.0",
        "symfony/ux-turbo": "^3.0",
        "symfony/ux-twig-component": "^3.0",
        "symfony/validator": "8.0.*",
        "symfony/web-link": "8.0.*",
        "symfony/yaml": "8.0.*",
        "twig/extra-bundle": "^2.12|^3.24",
        "twig/twig": "^2.12|^3.24"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts",
            "App\\Composer\\Hooks::printDevHints"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test": "phpunit --testsuite=unit,component,functional --no-coverage",
        "test:unit": "phpunit --testsuite=unit --no-coverage",
        "test:component": "phpunit --testsuite=component --no-coverage",
        "test:functional": "phpunit --testsuite=functional --no-coverage",
        "test:coverage": "phpunit --testsuite=unit,component,functional",
        "coverage:check": "bin/coverage-threshold --min=80",
        "coverage:gate": [
            "@test:coverage",
            "@coverage:check"
        ],
        "tools:install": [
            "@composer install -d tools/phpstan --no-interaction --no-progress",
            "@composer install -d tools/php-cs-fixer --no-interaction --no-progress",
            "@composer install -d tools/rector --no-interaction --no-progress",
            "@composer install -d tools/infection --no-interaction --no-progress"
        ],
        "tools:update": [
            "@composer update -d tools/phpstan --no-interaction --no-progress",
            "@composer update -d tools/php-cs-fixer --no-interaction --no-progress",
            "@composer update -d tools/rector --no-interaction --no-progress",
            "@composer update -d tools/infection --no-interaction --no-progress"
        ],
        "phpstan": "tools/phpstan/vendor/bin/phpstan analyse --memory-limit=1G",
        "cs:check": "tools/php-cs-fixer/vendor/bin/php-cs-fixer check --diff",
        "cs:fix": "tools/php-cs-fixer/vendor/bin/php-cs-fixer fix",
        "rector": "tools/rector/vendor/bin/rector process",
        "rector:dry": "tools/rector/vendor/bin/rector process --dry-run",
        "infection": "tools/infection/vendor/bin/infection --threads=max --show-mutations --min-msi=60",
        "infection:dry": "tools/infection/vendor/bin/infection --threads=max --dry-run",
        "quality": [
            "@cs:check",
            "@phpstan"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    },
    "require-dev": {
        "mtdowling/jmespath.php": "^2.8",
        "phpunit/phpunit": "^13.1.8",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/stopwatch": "8.0.*",
        "symfony/web-profiler-bundle": "8.0.*",
        "zenstruck/assert": "^1.7",
        "zenstruck/browser": "^1.10",
        "zenstruck/foundry": "^2.9.2"
    }
}
