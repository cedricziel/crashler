# Copy this file to .env.deploy (gitignored) and fill in the values for
# every stage you deploy to. Each variable is also accepted as a real
# shell environment variable, so CI can put them in a secret store.
#
# Variable naming: ${STAGE}_DEPLOY_${KEY} where STAGE is uppercased.
# A stage whose HOST is not set is silently skipped at deploy time.

###> production ###
# PRODUCTION_DEPLOY_HOST=crashler.example.com
# PRODUCTION_DEPLOY_USER=deployer
# PRODUCTION_DEPLOY_PATH=/var/www/crashler
# PRODUCTION_DEPLOY_HTTP_USER=www-data
# PRODUCTION_DEPLOY_BRANCH=main

# Optional:
# PRODUCTION_DEPLOY_PORT=22
# PRODUCTION_DEPLOY_IDENTITY_FILE=~/.ssh/crashler_prod_ed25519

# Override the remote PHP binary if it isn't on PATH or has a non-standard
# name. All-Inkl uses /usr/bin/php85 / php84 / php83 / etc. Mittwald and
# Hetzner Cloud use the more conventional /usr/bin/php8.5.
# DEPLOY_PHP_BIN=/usr/bin/php85

# Required on managed hosts that lack sudo and ACL support. Skips the
# chown/setfacl step in deploy:writable.
# DEPLOY_WRITABLE_MODE=chmod

# One-shot purge of all existing Parquet files under the shared logs
# directory before the new release is installed. Set to '1' only when
# rolling out a schema-breaking change; unset (or 0) otherwise. The
# crashler:purge_old_logs Deployer task gates on this exact value.
# CRASHLER_PURGE_OLD_LOGS_ON_DEPLOY=1
###< production ###

###> staging ###
# STAGING_DEPLOY_HOST=crashler-staging.example.com
# STAGING_DEPLOY_USER=deployer
# STAGING_DEPLOY_PATH=/var/www/crashler
# STAGING_DEPLOY_HTTP_USER=www-data
# STAGING_DEPLOY_BRANCH=main

# Optional:
# STAGING_DEPLOY_PORT=22
# STAGING_DEPLOY_IDENTITY_FILE=~/.ssh/crashler_staging_ed25519
###< staging ###
